# ─────────────────────────────────────────────────────────────────
# LiveKit Latency Test Suite — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────


# ── HOW TOKEN GENERATION WORKS ────────────────────────────────────
#
#   A LiveKit token is a JWT signed with API_KEY + API_SECRET.
#   The server URL is NOT used to generate a token — it is only
#   needed when connecting to the room.
#
#   Token generation  →  needs: LIVEKIT_API_KEY + LIVEKIT_API_SECRET
#   Room connection   →  needs: LIVEKIT_URL + <token>
#
#   Where to find API_KEY and API_SECRET (self-hosted LiveKit):
#     Open your LiveKit server config file (livekit.yaml):
#       keys:
#         <YOUR_API_KEY>: <YOUR_API_SECRET>
# ─────────────────────────────────────────────────────────────────


# ── LiveKit Connection ────────────────────────────────────────────

LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_HOST=your-livekit-server.com
LIVEKIT_PORT=7880
LIVEKIT_WS_URL=wss://your-livekit-server.com


# ── Token Signing Credentials ─────────────────────────────────────

LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here


# ── Pre-generated Token (optional — leave blank to auto-generate) ─

LIVEKIT_TOKEN=


# ── Agent Dispatch ────────────────────────────────────────────────
#
#   Your agent runs in the background and auto-joins any room
#   where it is dispatched by name. You do NOT need the agent's
#   host/port — LiveKit handles routing internally.
#
#   This name is passed as room metadata at creation time so
#   LiveKit dispatches the correct agent into the test room.

LIVEKIT_AGENT_NAME=your-agent-name


# ── Room Configuration ────────────────────────────────────────────

LIVEKIT_ROOM=latency-test-room
BOT_IDENTITY_PREFIX=latency-bot


# ── Test Run Configuration ────────────────────────────────────────

TEST_RUNS=20
TEST_DELAY=2.0
RESULTS_DIR=results
