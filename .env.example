# ─────────────────────────────────────────────────────────────────
# LiveKit Latency Test Suite — Environment Variables
# ─────────────────────────────────────────────────────────────────
# cp .env.example .env   # then fill in your values
# ─────────────────────────────────────────────────────────────────

# ── LiveKit Connection ────────────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_HOST=your-livekit-server.com
LIVEKIT_PORT=7880
LIVEKIT_WS_URL=wss://your-livekit-server.com

# ── Credentials ──────────────────────────────────────────────────
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# ── Agent ────────────────────────────────────────────────────────
LIVEKIT_AGENT_NAME=your-agent-name

# ── Test Configuration ───────────────────────────────────────────
LIVEKIT_ROOM=latency-test-room
BOT_IDENTITY_PREFIX=latency-bot
TEST_RUNS=10
TEST_DELAY=2.0
RESULTS_DIR=results
