{
  "name": "livekit-latency-tests",
  "version": "2.0.0",
  "description": "Complete latency test suite for LiveKit WebRTC + AI agent",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test:e2e": "node scripts/test_e2e_latency.js",
    "test:ttfb": "node scripts/test_ttfb.js",
    "test:network": "node scripts/test_network_rtt.js",
    "test:all": "npm run test:e2e && npm run test:ttfb && npm run test:network && npm run analyze",
    "analyze": "node scripts/analyze_results.js",
    "token": "node scripts/token_generator.js"
  },
  "dependencies": {
    "@livekit/rtc-node": "^0.12.0",
    "livekit-server-sdk": "^2.0.0",
    "dotenv": "^16.0.0",
    "ws": "^8.0.0",
    "minimist": "^1.2.8"
  }
}
